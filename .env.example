# Required — change both values before running
AGENT_TOKEN=change-me-long-random-string
JWT_SECRET=change-me-long-random-string

# Backend
PORT=4000
DATABASE_URL=./data/stackwatch.db

# Agent
POLL_INTERVAL=30000
CONFIG_PATH=/etc/stackwatch/config.yml

# Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=

# Stripe — only needed for the hosted $3/mo tier
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
FRONTEND_URL=http://localhost:3000
